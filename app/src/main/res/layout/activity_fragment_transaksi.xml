<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 🔹 Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riwayat Transaksi"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1B4332"/>

        <!-- 🔹 Filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <EditText
                android:id="@+id/etDari"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dari (YYYY-MM-DD)"
                android:inputType="date"
                android:padding="10dp"
                android:drawableEnd="@android:drawable/ic_menu_today"
                android:background="@android:drawable/edit_text"/>

            <EditText
                android:id="@+id/etSampai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Sampai (YYYY-MM-DD)"
                android:inputType="date"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:drawableEnd="@android:drawable/ic_menu_today"
                android:background="@android:drawable/edit_text"/>
        </LinearLayout>

        <!-- 🔹 Tombol -->
        <Button
            android:id="@+id/btnTampil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tampilkan Data"
            android:layout_marginTop="10dp"
            android:backgroundTint="#1B4332"
            android:textColor="#FFFFFF"/>

        <!-- 🔹 Total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Pendapatan"
                android:textColor="#666"/>

            <TextView
                android:id="@+id/tvTotalPendapatan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 🔹 List Transaksi -->
        <ListView
            android:id="@+id/listTransaksi"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="16dp"
            android:dividerHeight="8dp"/>

    </LinearLayout>
</ScrollView>