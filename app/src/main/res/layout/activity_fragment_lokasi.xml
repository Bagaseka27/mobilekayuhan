<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F4E1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manajemen Lokasi"
            android:textColor="#003322"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Bagian Cabang -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Daftar Cabang"
                    android:textColor="#003322"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_centerVertical="true"/>
                <Button
                    android:id="@+id/btnTambahCabang"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:text="+ Tambah Cabang"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:backgroundTint="#003322"
                    app:cornerRadius="8dp"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#CCCCCC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header Tabel -->
                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="1"
                        android:background="#F0F0F0">
                        <TableRow>
                            <TextView
                                android:text="ID"
                                android:textStyle="bold"
                                android:layout_weight="1"
                                android:textColor="#333333"
                                android:padding="12dp"
                                android:background="@drawable/table_cell_border"
                                android:gravity="center"/>
                            <TextView
                                android:text="Nama Lokasi"
                                android:textStyle="bold"
                                android:layout_weight="3"
                                android:textColor="#333333"
                                android:padding="12dp"
                                android:background="@drawable/table_cell_border"/>
                            <TextView
                                android:text="Aksi"
                                android:textStyle="bold"
                                android:layout_weight="1"
                                android:textColor="#333333"
                                android:padding="12dp"
                                android:background="@drawable/table_cell_border"
                                android:gravity="center"/>
                        </TableRow>
                    </TableLayout>

                    <!-- Area Data Scrollable -->
                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="250dp">
                        <TableLayout
                            android:id="@+id/tableCabang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="1">
                            <!-- Diisi via Kotlin -->
                        </TableLayout>
                    </androidx.core.widget.NestedScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Bagian Rombong -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚲 Unit Rombong"
                    android:textColor="#003322"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_centerVertical="true"/>
                <Button
                    android:id="@+id/btnTambahRombong"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:text="+ Tambah Unit"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:backgroundTint="#003322"
                    app:cornerRadius="8dp"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#CCCCCC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header Tabel -->
                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="1"
                        android:background="#F0F0F0">
                        <TableRow>
                            <TextView
                                android:text="ID Unit"
                                android:textStyle="bold"
                                android:layout_weight="1"
                                android:textColor="#333333"
                                android:padding="12dp"
                                android:background="@drawable/table_cell_border"
                                android:gravity="center"/>
                            <TextView
                                android:text="Lokasi"
                                android:textStyle="bold"
                                android:layout_weight="3"
                                android:textColor="#333333"
                                android:padding="12dp"
                                android:background="@drawable/table_cell_border"/>
                            <TextView
                                android:text="Aksi"
                                android:textStyle="bold"
                                android:layout_weight="1"
                                android:textColor="#333333"
                                android:padding="12dp"
                                android:background="@drawable/table_cell_border"
                                android:gravity="center"/>
                        </TableRow>
                    </TableLayout>

                    <!-- Area Data Scrollable -->
                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="250dp">
                        <TableLayout
                            android:id="@+id/tableRombong"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="1">
                            <!-- Diisi via Kotlin -->
                        </TableLayout>
                    </androidx.core.widget.NestedScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>