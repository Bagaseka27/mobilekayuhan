<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E3B"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kelola Data Karyawan"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_centerVertical="true" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Email -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Email (PK)" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nama Lengkap -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nama Lengkap" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNamaLengkap"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPersonName" android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- No HP -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="No HP" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNoHp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="phone" android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Password" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:passwordToggleEnabled="true"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPassword" android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Role -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Role" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_marginBottom="12dp">
                <AutoCompleteTextView
                    android:id="@+id/spinnerRole"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Barista" android:textSize="13sp"
                    android:focusable="false" android:focusableInTouchMode="false"
                    android:padding="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ID Jabatan -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ID Jabatan" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_marginBottom="12dp">
                <AutoCompleteTextView
                    android:id="@+id/spinnerJabatan"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="1 - Admin" android:textSize="13sp"
                    android:focusable="false" android:focusableInTouchMode="false"
                    android:padding="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ID Cabang -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ID Cabang" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_marginBottom="12dp">
                <AutoCompleteTextView
                    android:id="@+id/spinnerCabang"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="-" android:textSize="13sp"
                    android:focusable="false" android:focusableInTouchMode="false"
                    android:padding="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ID Rombong -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ID Rombong" android:textColor="#444" android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_marginBottom="16dp">
                <AutoCompleteTextView
                    android:id="@+id/spinnerRombong"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="-" android:textSize="13sp"
                    android:focusable="false" android:focusableInTouchMode="false"
                    android:padding="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Simpan Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Simpan"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1B5E3B"
                app:cornerRadius="8dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>