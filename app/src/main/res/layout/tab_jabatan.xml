<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5E8"
    android:padding="16dp">

    <!-- Button Tambah Jabatan (kanan atas) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:layout_marginBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTambahJabatan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Jabatan"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:backgroundTint="#1B5E3B"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="#FFFFFF"
            app:iconSize="14dp" />
    </LinearLayout>

    <!-- Table Jabatan -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:text="ID"
                    android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="NAMA JABATAN"
                    android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="GAJI/HARI"
                    android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BONUS/CUP"
                    android:textColor="#555" android:textSize="10sp" android:textStyle="bold" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AKSI"
                    android:textColor="#555" android:textSize="10sp" android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvJabatan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>